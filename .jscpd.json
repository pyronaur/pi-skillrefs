{
	"threshold": 0,
	"reporters": ["console"],
	"minTokens": 40,
	"minLines": 3,
	"formats": ["typescript", "javascript"],
	"pattern": ["src/**/*.ts"],
	"ignore": [
		"**/node_modules/**",
		"**/.git/**",
		"**/dist/**",
		"**/build/**",
		"**/coverage/**",
		"**/out/**",
		"**/tmp/**",
		"**/.tmp/**",
		"**/temp/**",
		"**/test/**",
		"**/tests/**",
		"**/__tests__/**",
		"**/*.test.*"
	]
}