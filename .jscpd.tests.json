{
	"threshold": 0,
	"reporters": ["console"],
	"minTokens": 60,
	"minLines": 7,
	"formats": ["typescript", "javascript"],
	"pattern": ["test/**/*.mjs"],
	"ignore": [
		"**/node_modules/**",
		"**/.git/**",
		"**/dist/**",
		"**/build/**",
		"**/coverage/**",
		"**/out/**",
		"**/tmp/**",
		"**/.tmp/**",
		"**/temp/**"
	]
}