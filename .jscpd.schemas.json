{
	"threshold": 2,
	"reporters": ["console"],
	"mode": "strict",
	"minTokens": 20,
	"minLines": 3,
	"formats": ["typescript", "javascript"],
	"ignore": [
		"**/node_modules/**",
		"**/.git/**",
		"**/dist/**",
		"**/build/**",
		"**/coverage/**",
		"**/out/**",
		"**/tmp/**",
		"**/.tmp/**",
		"**/temp/**"
	]
}
